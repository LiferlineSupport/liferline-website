{
  "name": "liferline-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:browsers": "playwright test e2e/cross-browser-validation.spec.ts --project=chromium --project=firefox --project='Mobile Chrome'",
    "test:browsers:headed": "playwright test e2e/cross-browser-validation.spec.ts --headed --project=chromium --project=firefox --project='Mobile Chrome'",
    "test:production": "TEST_PRODUCTION_BUILD=1 playwright test e2e/cross-browser-validation.spec.ts --project=chromium --project=firefox --project='Mobile Chrome'",
    "precommit:test": "npm run build && npm run test:browsers",
    "predeploy": "npm run precommit:test"
  },
  "dependencies": {
    "@stripe/stripe-js": "^4.0.0",
    "next": "14.2.5",
    "proper-lockfile": "^4.1.2",
    "react": "^18",
    "react-dom": "^18",
    "stripe": "^16.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
